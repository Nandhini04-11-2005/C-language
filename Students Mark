#include <stdio.h>

int main()
{
int i;
float marks[5], total = 0, average;
printf("Enter marks for 5 subjects:\n");
for(i = 0; i < 5; i++) 
{
printf("Subject %d: ", i+1);
scanf("%f", &marks[i]);
total = total + marks[i];
}
average = total / 5;
printf("\nTotal Marks = %.2f\n", total);
printf("Average = %.2f\n", average);
if(average >= 50)
  printf("Result: Pass");
else
  printf("Result: Fail");
return 0;
}
