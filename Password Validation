#include <stdio.h>
#include <string.h>
int main() 
{
char password[50];
int i, length, hasUpper = 0, hasDigit = 0;
printf("Enter Password: ");
scanf("%s", password);
length = strlen(password);
if(length < 6)
{
printf("Weak Password! Minimum 6 characters required");
return 0;
}
for(i = 0; i < length; i++)
{
if(password[i] >= 'A' && password[i] <= 'Z')
{
  hasUpper = 1;
}
if(password[i] >= '0' && password[i] <= '9') 
{
  hasDigit = 1;
}
}
if(hasUpper && hasDigit)
{
 printf("Strong Password");
} 
else
{
printf("Password must contain at least one Capital Letter and one Number");
}
return 0;
}
